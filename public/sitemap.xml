<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="#stylesheet"?>
<!DOCTYPE urlset [
  <!ATTLIST xsl:stylesheet id ID #REQUIRED>
]>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
  
  <!-- Embedded Stylesheet -->
  <xsl:stylesheet id="stylesheet" version="1.0">
    <xsl:template match="/">
      <html>
        <head>
          <title>Site Map - favorodera.vercel.app</title>
          <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { 
              font-family: system-ui, -apple-system, sans-serif; 
              background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
              min-height: 100vh;
              display: flex;
              align-items: center;
              justify-content: center;
              padding: 40px 20px;
            }
            .card {
              background: white;
              border-radius: 20px;
              padding: 40px;
              max-width: 600px;
              width: 100%;
              box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            }
            h1 { 
              color: #333; 
              margin-bottom: 30px;
              font-size: 28px;
              text-align: center;
            }
            .url-item {
              background: #f8f9fa;
              border-radius: 12px;
              padding: 20px;
              margin-bottom: 20px;
              border-left: 4px solid #667eea;
            }
            .url-link {
              color: #667eea;
              font-size: 16px;
              font-weight: 600;
              text-decoration: none;
              word-break: break-all;
            }
            .url-link:hover { text-decoration: underline; }
            .meta {
              display: flex;
              gap: 20px;
              margin-top: 12px;
              font-size: 14px;
              color: #666;
            }
            .badge {
              background: #667eea;
              color: white;
              padding: 4px 12px;
              border-radius: 20px;
              font-size: 12px;
              font-weight: 600;
            }
          </style>
        </head>
        <body>
          <div class="card">
            <h1>Sitemap</h1>
            <xsl:for-each select="urlset/url">
              <div class="url-item">
                <a class="url-link" href="{loc}">
                  <xsl:value-of select="loc"/>
                </a>
                <div class="meta">
                  <span><xsl:value-of select="lastmod"/></span>
                  <span><xsl:value-of select="changefreq"/></span>
                  <span class="badge">Priority: <xsl:value-of select="priority"/></span>
                </div>
              </div>
            </xsl:for-each>
          </div>
        </body>
      </html>
    </xsl:template>
  </xsl:stylesheet>

  <url>
    <loc>https://favorodera.vercel.app</loc>
    <lastmod>2026-04-07</lastmod>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>
  
</urlset>